# MongoDB connection string (use MongoDB Atlas free tier)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nexachat?retryWrites=true&w=majority

# JWT secret key (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Google OAuth Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Server port
PORT=3000

# OTP Mode: 'demo' shows OTP in response, 'twilio' sends real SMS
OTP_MODE=demo

# Twilio credentials (only needed if OTP_MODE=twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
